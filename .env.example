# ============================================================
# 基础配置
# ============================================================
TZ=Asia/Shanghai
MY_DOMAIN=vps.example.com
ACME_EMAIL=ops@example.com
CF_API_TOKEN=cf_token_with_dns_edit_permission

# ============================================================
# 3X-UI 初始化凭证
# ============================================================
XUI_ADMIN_USER=admin
XUI_ADMIN_PWD=change_me_strong_password

# ============================================================
# OpenClaw / Kimi
# 在 https://www.kimi.com/code/console 创建 API Key
# ============================================================
KIMI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENCLAW_BASE_URL=http://openclaw:3000/v1

# ============================================================
# Open WebUI
# ============================================================
WEBUI_SECRET_KEY=change_me_long_random_secret

# ============================================================
# Grafana (monitoring stack)
# ============================================================
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=change_me_grafana_admin_password
