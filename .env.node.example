TZ=Asia/Shanghai

# NODE_1 base domain. Caddy derives:
# - https://NODE_1_DOMAIN:8443
# - https://admin.NODE_1_DOMAIN:8443
# - https://sub.NODE_1_DOMAIN:8443
NODE_1_DOMAIN=node-1.example.com

# Public Caddy HTTPS port on the host. Keep 8443 for parity with MASTER.
CADDY_HTTPS_PORT=8443

# Caddy ACME DNS challenge.
ACME_EMAIL=ops@example.com
CF_API_TOKEN=change_me_cloudflare_dns_api_token
